# Copy this file to .env and fill in your values
# Never commit the real .env to version control

SECRET_KEY=replace-this-with-a-long-random-string
OPENAI_API_KEY=                  # optional — enables AI skill extraction from resume
HEADLESS=true                    # set to false to see the browser during automation
MAX_APPLY_PER_RUN=20             # safety cap on applications per session
